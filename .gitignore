# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────
dist/
out/
build/
**/target/
*.vsix

# ── Rust ──────────────────────────────────────────────────────────────────
Cargo.lock
**/*.rs.bk

# ── Tauri bundled resources (large binaries — never commit these) ─────────
desktop-app/src-tauri/resources/llama/
desktop-app/src-tauri/resources/models/
desktop-app/src-tauri/icons/*.png
desktop-app/src-tauri/icons/*.ico
desktop-app/src-tauri/icons/*.icns

# ── Model files — never commit GGUF/weights to git ─────────────────────────
*.gguf
*.bin
*.safetensors

# ── Installer output ────────────────────────────────────────────────────────
*.exe
*.msi
*.AppImage
*.deb
*.rpm
!docs/**/*.exe

# ── Environment / secrets ───────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── TypeScript build info ───────────────────────────────────────────────────
*.tsbuildinfo
